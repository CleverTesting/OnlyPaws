"homepage": "https://CleverTesting.github.io/OnlyPaws"{
  "name": "onlypaws",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:api": "PATH=$HOME/.local/bin:$PATH tsx server/src/index.ts",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:api\"",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "vue-tsc --noEmit"
"predeploy": "npm run build",
"deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mongodb": "^7.2.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.5",
    "concurrently": "^9.1.2",
    "gh-pages": "^6.3.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vite": "^6.1.1",
    "vue-tsc": "^2.2.2"
  }
}
